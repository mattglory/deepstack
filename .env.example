# Bitflow public ticker API (no key required).
BITFLOW_TICKER_API=https://bitflow-sdk-api-gateway-7owjsmt8.uc.gateway.dev

# A read-only "sender" principal (any valid mainnet address works for read calls).
SENDER_ADDRESS=SP000000000000000000002Q6VF78

# Market-making parameters (the AI layer will tune these on a cadence; static for the spike).
TARGET_SPREAD_BPS=20
LP_RANGE_BPS=150
