# Public Stacks Blockchain API (Hiro). No key needed for read-only calls.
STACKS_API=https://api.mainnet.hiro.so

# Bitflow public ticker API (no key required).
BITFLOW_TICKER_API=https://bitflow-sdk-api-gateway-7owjsmt8.uc.gateway.dev

# A read-only "sender" principal (any valid mainnet address works for read calls).
SENDER_ADDRESS=SP000000000000000000002Q6VF78

# Market-making parameters (the AI layer will tune these on a cadence; static for the spike).
TARGET_SPREAD_BPS=20
LP_RANGE_BPS=150

# --- M1 broadcasting (KEEP SECRET; .env is gitignored; never share/paste this) ---
# Network for wallet + broadcasts. Defaults to testnet for safety.
STACKS_NETWORK=testnet
# Which XYK pair the agent operates on (registry in src/m1/contracts.ts).
# Known: sbtc-stx (default), stx-aeusdc. Adding a pair = one entry in PAIRS.
PAIR=sbtc-stx
# Your TEST wallet: a raw hex private key OR a 12/24-word seed phrase.
# Read only from here, never logged. (Seed phrase controls all accounts — use a test wallet.)
STACKS_PRIVATE_KEY=
# Which account to derive from a seed phrase (default 0; ignored for a raw key).
STACKS_ACCOUNT_INDEX=0

# --- AI tuning layer (optional). Without a key, the agent uses safe defaults. ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=~anthropic/claude-sonnet-latest

# --- Pilot ops (optional) ---
# Dead-man's-switch: create a check at healthchecks.io (period 30 min, grace 15 min)
# and paste its ping URL. The agent pings it every tick; a failed cycle pings /fail
# (immediate alert); a dead process pings nothing (alert after grace).
HEALTHCHECK_URL=

# RPC failover (see src/m1/rpc.ts). Comma-separated, tried in order after STACKS_API.
# Must serve the FULL Stacks Blockchain API (/extended/v1/...), e.g. a QuickNode
# Stacks mainnet endpoint (token goes in the URL) or a self-hosted stacks-blockchain-api.
STACKS_API_FALLBACKS=

# Telemetry mirror (see docs/PILOT_DEPLOY.md §5b): a secret gist the agent pushes
# dashboard/metrics.json to after every cycle, so the public dashboard stays live
# during the pilot. Token must be a CLASSIC PAT with ONLY the `gist` scope.
METRICS_GIST_ID=
METRICS_GIST_TOKEN=
