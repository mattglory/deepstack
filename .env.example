# Public Stacks Blockchain API (Hiro). No key needed for read-only calls.
STACKS_API=https://api.mainnet.hiro.so

# Bitflow public ticker API (no key required).
BITFLOW_TICKER_API=https://bitflow-sdk-api-gateway-7owjsmt8.uc.gateway.dev

# A read-only "sender" principal (any valid mainnet address works for read calls).
SENDER_ADDRESS=SP000000000000000000002Q6VF78

# Market-making parameters (the AI layer will tune these on a cadence; static for the spike).
TARGET_SPREAD_BPS=20
LP_RANGE_BPS=150

# --- M1 broadcasting (KEEP SECRET; .env is gitignored; never share/paste this) ---
# Network for wallet + broadcasts. Defaults to testnet for safety.
STACKS_NETWORK=testnet
# Your TEST wallet: a raw hex private key OR a 12/24-word seed phrase.
# Read only from here, never logged. (Seed phrase controls all accounts — use a test wallet.)
STACKS_PRIVATE_KEY=
# Which account to derive from a seed phrase (default 0; ignored for a raw key).
STACKS_ACCOUNT_INDEX=0
