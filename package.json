{
  "name": "deepstack",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Bitcoin-native liquidity / market-making agent for Stacks DeFi (PoC spike)",
  "scripts": {
    "spike": "tsx src/index.ts",
    "yield": "tsx src/yield/cli.ts",
    "m1:dryrun": "tsx src/m1/cli.ts",
    "m1:wallet": "tsx src/m1/wallet-cli.ts",
    "m1:testnet-ping": "tsx src/m1/testnet-ping-cli.ts",
    "m1:smoke": "tsx src/m1/smoke-cli.ts",
    "m1:agent": "tsx src/m1/agent-cli.ts",
    "m1:safety": "tsx src/m1/safety-cli.ts",
    "m1:lvr": "tsx src/m1/lvr-cli.ts",
    "test": "node --import tsx --test src/m1/*.test.ts",
    "typecheck": "tsc --noEmit",
    "m2:receiver": "tsx src/m2/receiver-cli.ts",
    "pilot:status": "bash deploy/watch.sh status",
    "pilot:watch": "bash deploy/watch.sh logs"
  },
  "dependencies": {
    "@stacks/transactions": "^7.0.0",
    "@stacks/wallet-sdk": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}